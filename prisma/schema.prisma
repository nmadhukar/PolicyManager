// PolicyManager Prisma schema.
// RULE (AGENTS.md §3): every model MUST declare @@schema("policytracker").
// No PolicyManager business objects in `public`.
// Models are added per phase as vertical slices — not one big dump.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["policytracker"]
}

// ---------------------------------------------------------------------------
// Phase 2 — Auth & RBAC
// ---------------------------------------------------------------------------

enum UserStatus {
  active
  disabled

  @@schema("policytracker")
}

model User {
  id                  String     @id @default(uuid())
  email               String     @unique
  name                String
  title               String?
  passwordHash        String?
  status              UserStatus @default(active)
  mfaSecret           String?
  // Forces a password change on next login (temp passwords / admin resets).
  mustChangePassword  Boolean    @default(false)
  // Brute-force lockout counters. `lockedUntil` in the future blocks login;
  // an explicit admin lock sets it far in the future (distinct from `status`).
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  roles                     UserRole[]
  identities                UserIdentity[]
  ownedDocuments            Document[]                 @relation("DocumentOwner")
  deletedDocuments          Document[]                 @relation("DocumentDeleter")
  uploadedVersions          DocumentVersion[]          @relation("VersionUploader")
  createdAcls               DocumentAcl[]              @relation("AclCreatedBy")
  auditEvents               AuditEvent[]               @relation("AuditActor")
  reviewAssignments         ReviewAssignment[]         @relation("ReviewAssignmentReviewer")
  createdReviewAssignments  ReviewAssignment[]         @relation("ReviewAssignmentCreator")
  assignedReviewTasks       ReviewTask[]               @relation("ReviewTaskAssignee")
  completedReviewTasks      ReviewTask[]               @relation("ReviewTaskCompleter")
  attestations              Attestation[]              @relation("AttestationUser")
  acknowledgmentAssignments AcknowledgmentAssignment[] @relation("AckAssignee")
  assignedAcknowledgments   AcknowledgmentAssignment[] @relation("AckAssignedBy")
  createdApiClients         ApiClient[]                @relation("ApiClientCreator")
  importBatches             ImportBatch[]              @relation("ImportBatchCreator")

  @@schema("policytracker")
}

model UserIdentity {
  id       String   @id @default(uuid())
  userId   String
  provider String // local | azure | google | okta | cognito ...
  subject  String
  email    String?
  linkedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, subject])
  @@schema("policytracker")
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?
  isSystem    Boolean @default(false)

  users       UserRole[]
  permissions RolePermission[]

  @@schema("policytracker")
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique // e.g. document.read
  description String?

  roles RolePermission[]

  @@schema("policytracker")
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@schema("policytracker")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@schema("policytracker")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@schema("policytracker")
}

/// Single-use, short-lived token backing self-service password reset. The RAW
/// token is emailed to the user and NEVER persisted — only its SHA-256 digest is
/// stored (like RefreshToken), so a DB read cannot reconstruct a usable link.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@schema("policytracker")
}

// ---------------------------------------------------------------------------
// Phase 3 — Documents & Versioning
// ---------------------------------------------------------------------------

enum DocumentStatus {
  draft
  in_review
  approved
  published
  archived
  retired

  @@schema("policytracker")
}

enum AccessLevel {
  public
  restricted
  confidential

  @@schema("policytracker")
}

enum ReviewCadence {
  none
  quarterly
  annual
  custom

  @@schema("policytracker")
}

/// Hierarchical folder for documents (Policies & Procedures, Job Descriptions,
/// IOP/PHP Curriculum, Forms…). `parentId` gives an arbitrary-depth tree.
model DocumentCategory {
  id          String   @id @default(uuid())
  name        String
  parentId    String?
  description String?
  createdAt   DateTime @default(now())

  parent    DocumentCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  DocumentCategory[] @relation("CategoryTree")
  documents Document[]
  acls      DocumentAcl[]      @relation("CategoryAcl")

  // No two sibling categories share a name. NOTE (D12/C10): this compound unique
  // only constrains rows with a NON-NULL parentId (Postgres treats NULLs as
  // distinct), so a companion PARTIAL unique index on `name WHERE parentId IS NULL`
  // (migration `data_integrity_hardening`) enforces uniqueness among root categories.
  @@unique([name, parentId])
  @@index([parentId])
  @@schema("policytracker")
}

/// Stable logical document. The file bytes live in immutable DocumentVersion
/// rows; `currentVersionId` points at the version currently surfaced.
model Document {
  id               String          @id @default(uuid())
  title            String
  // Uniqueness is enforced by a PARTIAL unique index scoped to live documents
  // (`WHERE "deletedAt" IS NULL`), added in migration `data_integrity_hardening`.
  // A plain `@unique` would collide with soft-deleted rows and mis-report a
  // re-import of a number whose only holder is in the trash (C4/D3).
  documentNumber   String?
  categoryId       String?
  ownerId          String
  description      String?
  tags             String[]
  status           DocumentStatus  @default(draft)
  accessLevel      AccessLevel     @default(restricted)
  currentVersionId String?         @unique
  reviewCadence    ReviewCadence   @default(none)
  nextReviewDate   DateTime?
  effectiveDate    DateTime?
  // Soft-delete only (AGENTS.md §9): a non-null `deletedAt` hides the document
  // from default lists/reads but never removes the row or its version bytes.
  // `deletedById` records who trashed it. Both cleared on restore.
  deletedAt        DateTime?
  deletedById      String?
  // Lets archive/unarchive be reversible: the status held before archiving is
  // stashed here so unarchive can restore the exact prior lifecycle state.
  preArchiveStatus DocumentStatus?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  category                  DocumentCategory?          @relation(fields: [categoryId], references: [id])
  owner                     User                       @relation("DocumentOwner", fields: [ownerId], references: [id])
  deletedBy                 User?                      @relation("DocumentDeleter", fields: [deletedById], references: [id])
  // Nullable FK breaks the Document<->DocumentVersion cycle; NoAction avoids a
  // referential-action loop that Postgres would otherwise reject.
  currentVersion            DocumentVersion?           @relation("CurrentVersion", fields: [currentVersionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  versions                  DocumentVersion[]          @relation("DocumentVersions")
  acls                      DocumentAcl[]              @relation("DocumentAclDoc")
  auditEvents               AuditEvent[]               @relation("AuditDoc")
  reviewAssignments         ReviewAssignment[]         @relation("ReviewAssignmentDoc")
  reviewTasks               ReviewTask[]               @relation("ReviewTaskDoc")
  attestations              Attestation[]              @relation("AttestationDoc")
  acknowledgmentAssignments AcknowledgmentAssignment[] @relation("AckDoc")
  importItems               ImportItem[]               @relation("ImportItemDocument")

  @@index([title])
  @@index([categoryId])
  @@index([ownerId])
  @@index([status])
  @@index([nextReviewDate])
  @@index([deletedAt])
  @@schema("policytracker")
}

/// Immutable snapshot of a document's bytes. Every upload creates a new row +
/// new S3 object; prior version bytes are never overwritten (AGENTS.md §9).
model DocumentVersion {
  id             String         @id @default(uuid())
  documentId     String
  versionNumber  Int
  s3Key          String
  s3VersionId    String?
  renditionS3Key String?
  fileName       String
  mimeType       String
  // BigInt so files >2 GiB are represented exactly; serialized to a JS number in
  // the API projections (D10).
  sizeBytes      BigInt
  checksum       String
  uploadedById   String
  changeSummary  String?
  status         DocumentStatus @default(draft)
  extractedText  String?        @db.Text
  // Persisted existence flag for `extractedText`, set at write time. Lets list,
  // detail, and version reads compute "has text" WITHOUT selecting the (large)
  // @db.Text column on every row (D2). The text itself is read only where used
  // (public search / content).
  hasExtractedText Boolean      @default(false)
  createdAt      DateTime       @default(now())

  document                  Document                   @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  currentOf                 Document?                  @relation("CurrentVersion")
  uploadedBy                User                       @relation("VersionUploader", fields: [uploadedById], references: [id])
  attestations              Attestation[]              @relation("AttestationVersion")
  acknowledgmentAssignments AcknowledgmentAssignment[] @relation("AckVersion")

  @@unique([documentId, versionNumber])
  @@index([documentId])
  // Dedup hot path: import checksum lookups scan by checksum (D7).
  @@index([checksum])
  @@schema("policytracker")
}

// ---------------------------------------------------------------------------
// Phase 4 — Access Control & Audit
// ---------------------------------------------------------------------------

/// Whether an ACL grant targets a Role (all its members) or a single User.
enum AclPrincipalType {
  role
  user

  @@schema("policytracker")
}

/// The capability an ACL grant confers. `view`/`download` unlock read access to a
/// confidential document; `edit`/`approve` additionally gate those write actions.
enum AclPermission {
  view
  download
  edit
  approve

  @@schema("policytracker")
}

/// Where an audited action originated: the web app, the public API (Phase 7), or
/// an internal/server-to-server process (e.g. the OnlyOffice save callback).
enum AuditSource {
  web
  api
  system

  @@schema("policytracker")
}

/// A single access-control grant. Attached to EITHER a document OR a category
/// (exactly one of `documentId`/`categoryId` is set — enforced in the service);
/// a category grant cascades to every document in that category. `principalId`
/// is polymorphic (a roleId when principalType=role, a userId when =user) so it
/// intentionally has no FK. Confidential documents are visible/accessible ONLY to
/// the owner, an Admin, or a principal named by one of these grants.
model DocumentAcl {
  id            String           @id @default(uuid())
  documentId    String?
  categoryId    String?
  principalType AclPrincipalType
  principalId   String
  permission    AclPermission
  createdById   String
  createdAt     DateTime         @default(now())

  document  Document?         @relation("DocumentAclDoc", fields: [documentId], references: [id], onDelete: Cascade)
  category  DocumentCategory? @relation("CategoryAcl", fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy User              @relation("AclCreatedBy", fields: [createdById], references: [id])

  @@index([documentId])
  @@index([categoryId])
  @@index([principalType, principalId])
  @@schema("policytracker")
}

/// Immutable audit record of a security-relevant action (view/download/change/
/// access-denied/login…). Written best-effort out of the request path and NEVER
/// updated or deleted through app routes (AGENTS.md §8). Actor/document are
/// optional relations (SetNull on the — never-taken — hard delete) so an audit
/// row always survives as evidence. `apiClientId` is reserved for the Phase 7
/// public API and has no FK yet.
model AuditEvent {
  id          String      @id @default(uuid())
  actorUserId String?
  apiClientId String?
  action      String
  targetType  String?
  documentId  String?
  versionId   String?
  source      AuditSource @default(web)
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  actor    User?     @relation("AuditActor", fields: [actorUserId], references: [id])
  document Document? @relation("AuditDoc", fields: [documentId], references: [id])

  @@index([documentId])
  @@index([actorUserId])
  @@index([createdAt])
  @@index([action])
  @@schema("policytracker")
}

// ---------------------------------------------------------------------------
// Phase 5 — QC Review scheduling + Email/SMTP admin
// ---------------------------------------------------------------------------

/// Lifecycle of a scheduled review task. `pending`/`in_progress`/`overdue` are the
/// "open" states the sweep treats as outstanding; `completed`/`cancelled` are terminal.
enum ReviewTaskStatus {
  pending
  in_progress
  completed
  overdue
  cancelled

  @@schema("policytracker")
}

/// A reviewer assigned to a document's QC review cycle. Many reviewers per document;
/// the daily sweep raises one ReviewTask per assignment when the document comes due
/// (falling back to the document owner when there are no assignments).
model ReviewAssignment {
  id          String   @id @default(uuid())
  documentId  String
  reviewerId  String
  createdAt   DateTime @default(now())
  createdById String

  document  Document @relation("ReviewAssignmentDoc", fields: [documentId], references: [id], onDelete: Cascade)
  reviewer  User     @relation("ReviewAssignmentReviewer", fields: [reviewerId], references: [id])
  createdBy User     @relation("ReviewAssignmentCreator", fields: [createdById], references: [id])

  // One assignment per (document, reviewer) — assigning twice is idempotent.
  @@unique([documentId, reviewerId])
  @@index([documentId])
  @@index([reviewerId])
  @@schema("policytracker")
}

/// A dated, assignee-scoped unit of QC review work generated by the sweep. Captures
/// the document version under review (when known), the due date (the document's
/// nextReviewDate at generation time), and completion metadata. Attestation
/// (Phase 6) will hang off a completed task via `reviewTaskId` — left as a seam here.
model ReviewTask {
  id            String           @id @default(uuid())
  documentId    String
  versionId     String?
  dueDate       DateTime
  assignedToId  String
  status        ReviewTaskStatus @default(pending)
  completedAt   DateTime?
  completedById String?
  notes         String?
  createdAt     DateTime         @default(now())

  document     Document      @relation("ReviewTaskDoc", fields: [documentId], references: [id], onDelete: Cascade)
  assignedTo   User          @relation("ReviewTaskAssignee", fields: [assignedToId], references: [id])
  completedBy  User?         @relation("ReviewTaskCompleter", fields: [completedById], references: [id])
  attestations Attestation[] @relation("AttestationReviewTask")

  @@index([documentId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
  @@schema("policytracker")
}

/// Singleton SMTP configuration editable from the admin UI (fixed id `default`).
/// The password is stored ONLY as AES-256-GCM ciphertext in `passwordEncrypted`
/// (key from env APP_ENCRYPTION_KEY) — never plaintext (AGENTS.md §8). When
/// `enabled`, MailService prefers this over the SMTP_* env fallback.
model SmtpConfig {
  // Fixed singleton id: there is at most one SMTP config row ("default").
  id                String   @id @default("default")
  host              String
  port              Int
  secure            Boolean  @default(false)
  username          String?
  /// AES-256-GCM ciphertext (iv:tag:data, base64). NEVER the plaintext password.
  passwordEncrypted String?
  fromAddress       String
  fromName          String
  enabled           Boolean  @default(false)
  updatedAt         DateTime @updatedAt
  updatedById       String?

  @@schema("policytracker")
}

/// Immutable record of every attempted outbound email (review reminders, password
/// resets, test sends…). Written best-effort by MailService on each send; used by
/// the admin UI's delivery log and as operational evidence.
model NotificationLog {
  id           String   @id @default(uuid())
  toEmail      String
  toUserId     String?
  subject      String
  type         String
  reviewTaskId String?
  status       String // sent | failed
  error        String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([type])
  @@schema("policytracker")
}

// ---------------------------------------------------------------------------
// Phase 6 — Attestation (sign-off) + staff acknowledgment distribution
// ---------------------------------------------------------------------------

/// The compliance action an Attestation records:
///  - `reviewed`     — a QC reviewer signed off on a review task,
///  - `approved`     — an approver published/approved the document,
///  - `acknowledged` — a staff member confirmed "I have read and understand".
enum AttestationAction {
  reviewed
  approved
  acknowledged

  @@schema("policytracker")
}

/// Lifecycle of a staff acknowledgment assignment. `pending`/`overdue` are the
/// open states; `completed`/`cancelled` are terminal. A new published version
/// re-opens acknowledgment by creating a fresh `pending` assignment.
enum AckStatus {
  pending
  completed
  overdue
  cancelled

  @@schema("policytracker")
}

/// IMMUTABLE compliance sign-off evidence (AGENTS.md §8/§10b): reviewer/approver
/// e-attestation and staff read-and-acknowledge. Captures the signer, the exact
/// document version, a typed signature (name + role), the action, and the network
/// context (IP + user-agent) at sign time. There is NO update/delete route — a
/// correction is a new record, never a mutation (AGENTS.md §8).
model Attestation {
  id                         String            @id @default(uuid())
  documentId                 String
  // Nullable so a reviewer can still sign off on a metadata-only (no-file-yet)
  // document; approve/acknowledge always carry the current/published versionId.
  versionId                  String?
  reviewTaskId               String?
  acknowledgmentAssignmentId String?
  userId                     String
  action                     AttestationAction
  signatureName              String
  signatureRole              String?
  comments                   String?
  ipAddress                  String?
  userAgent                  String?
  signedAt                   DateTime          @default(now())
  createdAt                  DateTime          @default(now())

  // Restrict (NOT Cascade): an attestation is immutable compliance evidence, so a
  // raw DELETE of its document must FAIL rather than silently erase the sign-off
  // (D1). Soft-delete keeps the document + its evidence; a genuine purge must
  // remove evidence explicitly and deliberately.
  document                 Document                  @relation("AttestationDoc", fields: [documentId], references: [id], onDelete: Restrict)
  version                  DocumentVersion?          @relation("AttestationVersion", fields: [versionId], references: [id], onDelete: SetNull)
  user                     User                      @relation("AttestationUser", fields: [userId], references: [id])
  reviewTask               ReviewTask?               @relation("AttestationReviewTask", fields: [reviewTaskId], references: [id], onDelete: SetNull)
  acknowledgmentAssignment AcknowledgmentAssignment? @relation("AckAttestation", fields: [acknowledgmentAssignmentId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([versionId])
  @@index([userId])
  @@index([action])
  @@schema("policytracker")
}

/// Staff read-and-acknowledge distribution (AGENTS.md §10b). One row per
/// (published version, assignee). The unique constraint makes distribution
/// idempotent and lets a NEW version create fresh pending rows while prior
/// completed rows stay as historical evidence. Completion is proven by the linked
/// immutable `Attestation(action=acknowledged)`.
model AcknowledgmentAssignment {
  id           String    @id @default(uuid())
  documentId   String
  versionId    String
  assigneeId   String
  assignedById String
  dueDate      DateTime?
  status       AckStatus @default(pending)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  // Restrict (NOT Cascade): a completed assignment is backed by an immutable
  // acknowledged Attestation — compliance evidence that a raw document/version
  // DELETE must not silently erase (D1).
  document     Document        @relation("AckDoc", fields: [documentId], references: [id], onDelete: Restrict)
  version      DocumentVersion @relation("AckVersion", fields: [versionId], references: [id], onDelete: Restrict)
  assignee     User            @relation("AckAssignee", fields: [assigneeId], references: [id])
  assignedBy   User            @relation("AckAssignedBy", fields: [assignedById], references: [id])
  attestations Attestation[]   @relation("AckAttestation")

  // At most one assignment per (version, assignee) — distribution is idempotent
  // and a new versionId is what re-triggers acknowledgment.
  @@unique([versionId, assigneeId])
  @@index([documentId])
  @@index([assigneeId])
  @@index([status])
  @@schema("policytracker")
}

// ---------------------------------------------------------------------------
// Phase 7 — Public read-only API v1 (EMR / AI integration)
// ---------------------------------------------------------------------------

/// A machine client for the read-only public API (`/api/v1`). Authenticates with
/// `clientId.secret`; only the Argon2 hash of the high-entropy secret is stored —
/// the plaintext is shown to an operator exactly once at create/rotate time and is
/// NEVER recoverable (AGENTS.md §8). `scopes` gate capabilities
/// (documents:read / content:read / download); `allowedCategoryIds` optionally
/// restricts visibility to specific categories (empty = all). A client is usable
/// only while `enabled` and `revokedAt` is null. `clientId` is uniquely indexed
/// (the guard's hot lookup path).
model ApiClient {
  id                 String    @id @default(uuid())
  name               String
  clientId           String    @unique
  secretHash         String
  scopes             String[]
  allowedCategoryIds String[]
  enabled            Boolean   @default(true)
  createdAt          DateTime  @default(now())
  createdById        String?
  lastUsedAt         DateTime?
  revokedAt          DateTime?

  createdBy User? @relation("ApiClientCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@schema("policytracker")
}

// ---------------------------------------------------------------------------
// Phase 8 — Import & Consolidation (bulk upload + CSV manifest importer)
// ---------------------------------------------------------------------------

/// Outcome of processing one manifest row / bulk file. `pending` is the transient
/// state before a row is resolved; terminal states are `created` (a new Document +
/// version were made), `duplicate` (matched an existing document by number/
/// checksum/title+fileName — creation skipped), `error` (the row failed in
/// isolation without failing the batch), and `skipped` (reserved for rows a future
/// dry-run/preview mode chooses not to import).
enum ImportItemStatus {
  pending
  created
  duplicate
  error
  skipped

  @@schema("policytracker")
}

/// One bulk-import run (a CSV manifest upload or a manifest-less bulk file upload).
/// Aggregates per-row outcomes into rollup counters so the report can be shown
/// without re-scanning every item. `status` is the coarse batch lifecycle
/// (processing → completed, or failed if the whole run aborted). Counters are
/// authoritative — they equal the number of `ImportItem`s in each terminal state.
model ImportBatch {
  id             String    @id @default(uuid())
  createdById    String
  // Manifest file name for a CSV import; null for a manifest-less bulk upload.
  fileName       String?
  totalRows      Int
  createdCount   Int       @default(0)
  duplicateCount Int       @default(0)
  errorCount     Int       @default(0)
  // processing | completed | failed
  status         String    @default("processing")
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  createdBy User         @relation("ImportBatchCreator", fields: [createdById], references: [id])
  items     ImportItem[] @relation("ImportBatchItems")

  @@index([createdById])
  @@index([createdAt])
  @@schema("policytracker")
}

/// The immutable per-row result of an import (the "import report" line). Records
/// the source row's key fields for the report even when no Document was created,
/// plus a human-readable `message` (e.g. the duplicate reason or the error). Points
/// at the created OR matched Document via `documentId` (SetNull if that document is
/// later hard-removed — which the app never does, but the FK stays safe).
model ImportItem {
  id             String           @id @default(uuid())
  batchId        String
  rowNumber      Int
  title          String?
  documentNumber String?
  categoryName   String?
  fileName       String?
  status         ImportItemStatus @default(pending)
  documentId     String?
  message        String?
  createdAt      DateTime         @default(now())

  batch    ImportBatch @relation("ImportBatchItems", fields: [batchId], references: [id], onDelete: Cascade)
  document Document?   @relation("ImportItemDocument", fields: [documentId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@schema("policytracker")
}
