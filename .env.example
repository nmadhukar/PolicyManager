# ---------- Database ----------
# App owns the `policytracker` schema; never `public`.
DATABASE_URL="postgresql://policy:policy@localhost:5432/policymanager?schema=policytracker"

# ---------- API ----------
API_PORT=3000
NODE_ENV=development

# ---------- Auth ----------
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="7d"
AUTH_LOCAL_ENABLED=true

# ---------- OIDC / SSO (pluggable) ----------
OIDC_ENABLED=false
# OIDC_PROVIDERS=azure,google
# OIDC_CALLBACK_BASE_URL=http://localhost:3000
# OIDC_AZURE_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# OIDC_AZURE_CLIENT_ID=
# OIDC_AZURE_CLIENT_SECRET=
# OIDC_AZURE_SCOPES=openid profile email
# OIDC_GROUP_MAP={"BH-Admins":"Admin","Clinicians":"Staff"}

# ---------- S3 / MinIO ----------
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-2"
S3_BUCKET="policymanager-docs"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE=true
S3_PREFIX_DOCUMENTS="documents/"
S3_PREFIX_RENDITIONS="renditions/"
S3_PREFIX_COVERPAGES="coverpages/"
S3_PREFIX_IMPORTS="imports/"
S3_SSE=""
S3_KMS_KEY_ID=""
S3_AUTO_CREATE=true

# ---------- Email / SMTP ----------
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_ADDRESS="policymanager@example.com"
SMTP_FROM_NAME="PolicyManager"

# ---------- Document conversion / editing ----------
GOTENBERG_URL="http://localhost:3001"
ONLYOFFICE_URL="http://localhost:8080"
ONLYOFFICE_JWT_SECRET="change-me-onlyoffice"

# ---------- Web ----------
WEB_PORT=5173
VITE_API_BASE_URL="http://localhost:3000"
