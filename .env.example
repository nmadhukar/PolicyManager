# ---------- Database ----------
# App owns the `policytracker` schema; never `public`.
DATABASE_URL="postgresql://policy:policy@localhost:5432/policymanager?schema=policytracker"

# ---------- API ----------
API_PORT=3000
NODE_ENV=development
# Trusted reverse-proxy hop count. req.ip (audit + attestation IPs) honours this so
# X-Forwarded-For cannot be spoofed. 0 = trust none; behind one LB set 1.
TRUST_PROXY_HOPS=0
# CORS allow-list (comma-separated origins). Empty => reflect origin only in dev.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# ---------- Rate limiting ----------
# Global per-IP throttle (auth routes tighten to 10/min). Tune per deployment.
THROTTLE_TTL=60000
THROTTLE_LIMIT=300
# Set true ONLY for local/test runs. MUST remain false/unset in production.
THROTTLE_DISABLED=false

# ---------- Auth ----------
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="900s"
JWT_REFRESH_TTL="7d"
AUTH_LOCAL_ENABLED=true

# ---------- Encryption ----------
# Secret used to AES-256-GCM encrypt stored SMTP passwords (SHA-256-derived into a
# 32-byte key). Any string works; use a long random value in production. Rotating
# this invalidates previously stored SMTP passwords (re-enter them after a change).
APP_ENCRYPTION_KEY="change-me-app-encryption-key"

# ---------- OIDC / SSO — Azure AD (ADR 0003) ----------
# Set true to enable "Sign in with Microsoft" (GET /auth/oidc/azure). First-time
# SSO users are auto-created with the Staff role (no group->role mapping yet —
# an admin promotes them afterward via the existing user-management UI).
OIDC_ENABLED=false
# Base URL this API is reachable at from the browser; used to build the Azure AD
# redirect_uri (must exactly match what's registered on the Azure App
# Registration). NOT the internal Docker hostname.
OIDC_CALLBACK_BASE_URL=http://localhost:3000
# Tenant-specific v2.0 issuer, e.g.
# https://login.microsoftonline.com/<azure-tenant-id>/v2.0
OIDC_AZURE_ISSUER=
OIDC_AZURE_CLIENT_ID=
OIDC_AZURE_CLIENT_SECRET=
OIDC_AZURE_SCOPES="openid profile email"
# Extra web origins (comma-separated) allowed to receive SSO tokens via the
# ?returnTo= param on /api/auth/oidc/azure — e.g. the ESS Portal, so its users can
# sign in to PolicyManager via Microsoft (same Entra tenant) and use the chatbot
# as themselves. PolicyManager's own WEB_APP_URL/FRONTEND_URL are always allowed.
# SSO_ALLOWED_RETURN_ORIGINS=https://portal.example.com
# CORS: also add the ESS Portal origin to CORS_ALLOWED_ORIGINS so its browser may
# call /api/rag/chat directly (dev reflects any origin, so this matters in prod).

# ---------- S3 / MinIO ----------
S3_ENDPOINT="http://localhost:9000"
# Optional. Set this ONLY when the API reaches storage via a hostname the
# browser can't resolve (e.g. an internal Docker network name like
# `http://minio:9000`) — used exclusively when signing presigned download/
# view URLs, which the browser fetches directly. Defaults to S3_ENDPOINT.
# S3_PUBLIC_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-2"
S3_BUCKET="policymanager-docs"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_FORCE_PATH_STYLE=true
S3_PREFIX_DOCUMENTS="documents/"
S3_PREFIX_RENDITIONS="renditions/"
S3_PREFIX_COVERPAGES="coverpages/"
S3_PREFIX_IMPORTS="imports/"
S3_SSE=""
S3_KMS_KEY_ID=""
S3_AUTO_CREATE=true

# ---------- Email / SMTP ----------
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_ADDRESS="policymanager@example.com"
SMTP_FROM_NAME="PolicyManager"

# ---------- Document conversion / editing ----------
GOTENBERG_URL="http://localhost:3001"
# Max Gotenberg conversion time before the rendition attempt is abandoned (ms).
GOTENBERG_TIMEOUT_MS=60000

# ---------- OCR / searchable scanned documents ----------
# Disabled by default. When enabled, OCR_ENDPOINT must point at a self-hosted
# internal OCR gateway that accepts POST /ocr multipart file uploads and returns
# either text/plain or JSON { "text": "..." }.
OCR_ENABLED=false
OCR_ENDPOINT=""
OCR_TIMEOUT_MS=120000
OCR_MAX_BYTES=26214400
OCR_MAX_PAGES=50
OCR_PDF_MIN_TEXT_CHARS=24

# ---------- RAG / embeddings (semantic search for the ESS Portal chatbot) ----------
# Disabled by default (ADR-0002). When RAG_ENABLED=true AND OPENAI_API_KEY is set,
# a document version's extracted text is chunked and embedded (via OpenAI) into the
# pgvector-backed DocumentChunk table after extraction succeeds. With the flag off
# — or no key — NO chunk text is ever sent to OpenAI and the app behaves as before.
# NOTE (data egress): enabling this sends chunk text to OpenAI's embedding API.
RAG_ENABLED=false
OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
# Must match the vector(N) column dimension in the DocumentChunk migration (1536).
EMBEDDING_DIMENSIONS=1536
# Chunking: target chunk size and overlap, in approximate tokens.
RAG_CHUNK_MAX_TOKENS=500
RAG_CHUNK_OVERLAP_TOKENS=60
# Max texts per OpenAI embed request.
EMBEDDING_BATCH_SIZE=96
# Retrieval (Phase 2): hybrid vector+FTS search tuning.
# Max chunks returned; candidate pool per retriever before fusion; RRF constant.
RAG_RETRIEVAL_TOP_K=8
RAG_RETRIEVAL_CANDIDATE_POOL=40
RAG_FTS_CANDIDATE_POOL=40
RAG_RRF_K=60
# Max cosine distance (0=identical, 2=opposite) for a chunk to count as relevant.
# Off-topic questions (greetings, uncovered topics) fall below this → no sources,
# and the bot gives a friendly conversational reply instead of citing weak matches.
RAG_RETRIEVAL_MAX_DISTANCE=0.72
# Production retrieval (Phase 3): a third INDEPENDENT exact-identifier leg fires when
# a query names a section id (Policy 705, SOP-0045, Section 504, Clause 8.3, Article IV).
RAG_EXACT_CANDIDATE_POOL=20
# Additive score boost so an explicitly-requested section outranks similar chunks.
RAG_EXACT_MATCH_BOOST=1.0
# Adjacent chunks (chunkIndex ± N) pulled around each anchor for continuous context;
# neighbors stay within the same version + section. 0 disables expansion.
RAG_ADJACENT_EXPANSION=1
# Multi-document intelligence (Phase 4): max ANCHOR chunks one document may contribute
# to the final result, so a large document can't monopolize a broad query. Exact-section
# requests bypass this cap. 0 disables the cap.
RAG_MAX_CHUNKS_PER_DOCUMENT=3
# Max characters of grounding context assembled from retrieved chunks (Phase 3).
RAG_CONTEXT_MAX_CHARS=8000
# Chat / grounded answers (Phase 4). The chat model, how many prior turns to
# include, the answer token cap, and temperature (low = grounded/deterministic).
OPENAI_CHAT_MODEL="gpt-4o-mini"
RAG_CHAT_HISTORY_TURNS=6
RAG_CHAT_MAX_TOKENS=700
RAG_CHAT_TEMPERATURE=0.1
# Hardening (Phase 6). Query-embedding cache (0 TTL disables it) and a dedicated
# per-client rate limit on POST /rag/chat (each call can hit OpenAI). 429 on excess.
RAG_EMBED_CACHE_TTL_MS=300000
RAG_EMBED_CACHE_MAX=500
RAG_CHAT_RATE_LIMIT=20
RAG_CHAT_RATE_TTL_MS=60000

ONLYOFFICE_URL="http://localhost:8080"
# Required (no shipped default). Use a long random value; must match the Docs server.
ONLYOFFICE_JWT_SECRET="change-me-onlyoffice"
# Hosts the OnlyOffice save-callback may fetch edited bytes from (comma-separated).
# Empty trusts the Docs-server host + loopback (dev); set explicitly in prod (SSRF).
# ONLYOFFICE_DOWNLOAD_ALLOWED_HOSTS=docs.example.com
# URL the OnlyOffice DocumentServer container uses to reach THIS API for document
# bytes + save callbacks. On Docker Desktop (Win/Mac) the container reaches the
# host via host.docker.internal, NOT localhost. On Linux, the onlyoffice service
# in docker-compose maps host.docker.internal to host-gateway.
ONLYOFFICE_API_INTERNAL_URL="http://host.docker.internal:3000"

# ---------- Web ----------
WEB_PORT=5173
VITE_API_BASE_URL="http://localhost:3000"
# Public OnlyOffice DocumentServer URL the browser loads the editor API from.
VITE_ONLYOFFICE_URL="http://localhost:8080"
# Public base URL of the web app, used to build password-reset links in emails.
# WEB_APP_URL takes precedence if set; otherwise FRONTEND_URL is used.
FRONTEND_URL="http://localhost:5173"
